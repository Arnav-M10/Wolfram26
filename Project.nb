Cell[CellGroupData[{
Cell["\<\
Spectral Signatures of Deficit-Angle Curvature in Regge Triangulated \
Piecewise-Linear Einstein Geometry through Random Matrix Theory, Graph \
Laplacian Universality, Eigenvalue Repulsion, and Wigner\[Dash]Dyson Spectral \
Statistics\
\>", "Title",
 CellChangeTimes->{{3.99184165267448*^9, 3.991841674071299*^9}, {
   3.991841709530284*^9, 3.991841714126135*^9}, 
   3.991841786691551*^9},ExpressionUUID->"b560d59e-bd6e-4c4d-b963-\
e3e3ecf11f5d"],

Cell[CellGroupData[{

Cell["Arnav Mittal", "Chapter",
 CellChangeTimes->{{3.99184184761936*^9, 
  3.9918418504884787`*^9}},ExpressionUUID->"a6f7dc45-6e5a-42d8-8213-\
b566db06ff6d"],

Cell[CellGroupData[{

Cell["", "ChatBlockDivider",ExpressionUUID->"80623c45-acfc-4012-9dd9-04fae18280e1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"plotGrapher", "[", "n_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"flatPlot", ",", "perturbedPlot", ",", "conePlot"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"flatPlot", "=", 
      RowBox[{"Plot3D", "[", 
       RowBox[{"0", ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Mesh", "->", "n"}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotStyle", "->", "Blue"}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "0.5"}], ",", "0.5"}], "}"}]}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"PlotLabel", "->", "\"\<Flat Surface\>\""}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", " ", "\[IndentingNewLine]", 
     RowBox[{"perturbedPlot", "=", 
      RowBox[{"Plot3D", "[", 
       RowBox[{
        RowBox[{"0.5", " ", 
         RowBox[{"Sin", "[", "x", "]"}], " ", 
         RowBox[{"Cos", "[", "y", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Mesh", "->", "n"}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotStyle", "->", "Red"}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "0.6"}], ",", "0.6"}], "}"}]}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"PlotLabel", "->", "\"\<Perturbed Surface\>\""}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"conePlot", "=", 
      RowBox[{"Plot3D", "[", 
       RowBox[{
        RowBox[{"1.5", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "+", 
           RowBox[{"y", "^", "2"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Mesh", "->", "n"}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotStyle", "->", "Green"}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"PlotLabel", "->", "\"\<Cone Surface\>\""}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"GraphicsRow", "[", 
      RowBox[{"{", 
       RowBox[{"flatPlot", ",", "perturbedPlot", ",", "conePlot"}], "}"}], 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.99182100550156*^9, 3.991821005501697*^9}, {
  3.991821043245462*^9, 3.991821044890503*^9}, {3.991821092101294*^9, 
